# Copia este archivo a .env y completa los valores
# cp .env.example .env

# Django
SECRET_KEY=
DEBUG=True

# Base de datos
DATABASE_URL=sqlite:///db.sqlite3

# Seguridad — requerido cuando DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — True en desarrollo, False en produccion
CORS_ALLOW_ALL_ORIGINS=True
