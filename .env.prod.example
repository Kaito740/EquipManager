# Copia este archivo a .env y completa los valores
# cp .env.example .env

# Django
SECRET_KEY=
DEBUG=False

# Base de datos
DATABASE_URL=postgres://postgres:postgres@db:5432/equipmanager

# Seguridad — requerido cuando DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — True en desarrollo, False en produccion
CORS_ALLOW_ALL_ORIGINS=http://localhost
